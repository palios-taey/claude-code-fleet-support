#!/usr/bin/env python3
"""cf-support-intake — Phase 0 GitHub webhook intake + support queue consumer."""

from __future__ import annotations

import argparse
import os
import sys
import threading

import uvicorn


def _bootstrap_path() -> None:
    repo_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    install_root = "/usr/local/lib/claude-code-fleet-support"
    for candidate in (repo_root, install_root):
        if candidate not in sys.path:
            sys.path.insert(0, candidate)


def main() -> None:
    _bootstrap_path()
    from lib.runtime import SupportRuntime, create_app, run_consumer

    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--once", action="store_true", help="Process one queued support event and exit")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8045)
    args = parser.parse_args()

    runtime = SupportRuntime()
    if args.once:
        runtime.process_next_event(timeout=1)
        return

    stop_event = threading.Event()
    consumer = threading.Thread(target=run_consumer, args=(stop_event, runtime), daemon=True)
    consumer.start()
    try:
        uvicorn.run(create_app(runtime), host=args.host, port=args.port, log_level="info")
    finally:
        stop_event.set()
        consumer.join(timeout=2)


if __name__ == "__main__":
    main()
